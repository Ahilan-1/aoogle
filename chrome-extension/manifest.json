{
  "manifest_version": 3,
  "name": "aoogle Sidebar",
  "version": "1.0",
  "description": "Shows aoogle search results in a sidebar when you search on other search engines.",
  "permissions": ["storage"],
  "host_permissions": ["https://aoogle-production.up.railway.app/*", "http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://google.com/search*",
        "https://www.bing.com/search*",
        "https://bing.com/search*",
        "https://duckduckgo.com/*",
        "https://search.yahoo.com/search*",
        "https://yandex.com/search/*",
        "https://yandex.ru/search/*",
        "https://www.baidu.com/s*",
        "https://baidu.com/s*",
        "https://search.brave.com/search*",
        "https://www.ecosia.org/search*",
        "https://ecosia.org/search*",
        "https://www.qwant.com/*",
        "https://qwant.com/*",
        "https://www.searx.be/search*",
        "https://searx.be/search*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
